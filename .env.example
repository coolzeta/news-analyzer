# =============================================================================
# Market News Intelligence System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values
# Docker Compose will automatically read from the root .env file

# =============================================================================
# LLM Configuration (Required)
# =============================================================================
# Get your API key from: https://openrouter.ai (recommended)
LLM_API_KEY=your_api_key_here
LLM_PROVIDER=openrouter
LLM_MODEL=minimax/minimax-m2.7

# =============================================================================
# Main Service Settings
# =============================================================================
# URL of the agent service (for LLM analysis)
AGENT_SERVICE_URL=http://localhost:8001
# Timeout for agent analysis requests (seconds)
AGENT_TIMEOUT=120
# Auto-analyze new articles as they arrive
AUTO_ANALYZE=true

# =============================================================================
# Collector Settings
# =============================================================================
# Interval between collection cycles (minutes)
COLLECT_INTERVAL_MINUTES=1
# Embedding model for vector deduplication
EMBEDDING_MODEL=google/gemini-embedding-001
# Similarity threshold for deduplication (0.0-1.0, higher = stricter)
SIMILARITY_THRESHOLD=0.65

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# =============================================================================
# Service URLs (for local development - Docker uses internal networking)
# =============================================================================
# These are used when running services locally without Docker
# MAIN_SERVICE_URL=http://localhost:8000
# AGENT_SERVICE_URL=http://localhost:8001
# NEXT_PUBLIC_API_URL=http://localhost:8000

# =============================================================================
# Storage Paths (for local development - Docker uses container paths)
# =============================================================================
# CHROMA_PERSIST_DIR=./chroma_data
# FAILED_ARTICLES_FILE=./failed_articles.json

# =============================================================================
# NewsAPI (Optional - for additional news sources)
# =============================================================================
# NEWSAPI_API_KEY=your_newsapi_key_here
